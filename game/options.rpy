################################################################################
## Конфігурація збірки
################################################################################
##
## Керує тим, як Ren'Py пакує проєкт у файли розповсюдження.
## У шаблоні: "/" — роздільник тек, "*" — будь-які символи крім "/",
## "**" — будь-які символи, включно з "/".

init python:

    ## Файли, що НЕ потрапляють у збірку взагалі.
    build.classify('**~', None)
    build.classify('**.bak', None)
    build.classify('**/.**', None)
    build.classify('**/#**', None)
    build.classify('**/thumbs.db', None)

    ## Зображення пакуються в архів (.rpa), а не лишаються окремими файлами.
    build.classify('game/**.png', 'archive')
    build.classify('game/**.jpg', 'archive')

    ## Файли документації дублюються в збірці застосунку для Mac —
    ## з'являються і в самому застосунку, і окремо в zip-файлі.
    build.documentation('*.html')
    build.documentation('*.txt')


